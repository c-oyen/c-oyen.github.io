---
import "../styles/global.css";

interface Props {
    title?: string;
    description?: string;
}

const {
    title = "c-oyen — developer & orange cat energy",
    description = "Si Oyen — a developer who builds random things, breaks stuff responsibly, and runs on curiosity, coffee, and orange-cat energy.",
} = Astro.props;
---

<!doctype html>
<html lang="en">
    <head>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1.0" />
        <meta name="description" content={description} />
        <link
            rel="icon"
            type="image/png"
            href="/favicon-96x96.png"
            sizes="96x96"
        />
        <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
        <link rel="shortcut icon" href="/favicon.ico" />
        <link
            rel="apple-touch-icon"
            sizes="180x180"
            href="/apple-touch-icon.png"
        />
        <meta name="apple-mobile-web-app-title" content="c-oyen" />
        <link rel="manifest" href="/site.webmanifest" />
        <title>{title}</title>

        <!-- Open Graph -->
        <meta property="og:title" content={title} />
        <meta property="og:description" content={description} />
        <meta property="og:type" content="website" />
        <meta property="og:url" content="https://c-oyen.github.io" />
    </head>
    <body>
        <slot />
    </body>
</html>
