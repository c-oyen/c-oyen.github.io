---
---

<section id="hero" class="dot-grid" style="
  min-height: 100vh;
  display: flex;
  align-items: center;
  padding: 8rem 1.5rem 4rem;
  position: relative;
  overflow: hidden;
">

  <!-- Decorative blobs -->
  <div style="
    position: absolute;
    top: 15%;
    right: 8%;
    width: 320px;
    height: 320px;
    background: radial-gradient(circle, rgba(255,107,53,0.12) 0%, transparent 70%);
    border-radius: 50%;
    pointer-events: none;
  "></div>
  <div style="
    position: absolute;
    bottom: 20%;
    left: 5%;
    width: 200px;
    height: 200px;
    background: radial-gradient(circle, rgba(255,107,53,0.07) 0%, transparent 70%);
    border-radius: 50%;
    pointer-events: none;
  "></div>

  <div style="max-width: 820px; margin: 0 auto; width: 100%;">

    <!-- Tag line -->
    <div style="display: flex; align-items: center; gap: 10px; margin-bottom: 2rem; animation: fadeUp 0.5s ease forwards;">
      <span class="section-tag">// portfolio</span>
      <div style="width: 40px; height: 1px; background: var(--orange); opacity: 0.5;"></div>
      <span style="font-family: var(--mono); font-size: 0.68rem; color: var(--ink-faint);">still shipping things...</span>
      <span style="
        display: inline-block;
        width: 8px; height: 8px;
        border-radius: 50%;
        background: #22c55e;
        box-shadow: 0 0 0 3px rgba(34,197,94,0.2);
        animation: pulse-dot 2s ease-in-out infinite;
      "></span>
    </div>

    <!-- Name + Cat -->
    <div style="display: flex; align-items: flex-start; gap: 1rem; margin-bottom: 1.5rem;">
      <h1 style="
        font-family: var(--display);
        font-size: clamp(3rem, 10vw, 6.5rem);
        font-weight: 800;
        line-height: 1;
        color: var(--ink);
        margin: 0;
        animation: fadeUp 0.6s 0.1s ease both;
      ">
        c<span style="color: var(--orange);">-</span>oyen
      </h1>
      <div class="animate-float" style="font-size: clamp(2.5rem, 7vw, 4.5rem); line-height: 1; margin-top: 4px;">🐈</div>
    </div>

    <!-- Subtitle -->
    <p style="
      font-size: clamp(1rem, 2.5vw, 1.25rem);
      color: var(--ink-muted);
      max-width: 560px;
      margin-bottom: 2.5rem;
      animation: fadeUp 0.6s 0.2s ease both;
    ">
      <em>"Si Oyen"</em> — an Indonesian nickname for orange cats.<br/>
      Chaotic, curious, and sometimes surprisingly smart.
    </p>

    <!-- Terminal snippet -->
    <div style="
      display: inline-block;
      background: var(--ink);
      border-radius: 12px;
      padding: 1rem 1.5rem;
      font-family: var(--mono);
      font-size: 0.82rem;
      margin-bottom: 2.5rem;
      animation: fadeUp 0.6s 0.3s ease both;
      min-width: 280px;
    ">
      <div style="display: flex; gap: 6px; margin-bottom: 10px;">
        <span style="width:10px;height:10px;border-radius:50%;background:#ff5f57;display:inline-block;"></span>
        <span style="width:10px;height:10px;border-radius:50%;background:#febc2e;display:inline-block;"></span>
        <span style="width:10px;height:10px;border-radius:50%;background:#28c840;display:inline-block;"></span>
      </div>
      <div style="color: var(--ink-faint);">$ <span style="color: #FF8C5A;">whoami</span></div>
      <div style="color: white; margin: 2px 0 6px;">c-oyen</div>
      <div style="color: var(--ink-faint);">$ <span style="color: #FF8C5A;">status</span></div>
      <div style="color: white; display: flex; align-items: center;">still shipping things<span class="cursor"></span></div>
    </div>

    <!-- CTA links -->
    <div style="display: flex; flex-wrap: wrap; gap: 12px; animation: fadeUp 0.6s 0.4s ease both;">
      <a href="#stack" style="
        padding: 10px 22px;
        background: var(--orange);
        color: white;
        border-radius: 99px;
        text-decoration: none;
        font-weight: 600;
        font-size: 0.9rem;
        transition: all 0.15s;
        display: flex;
        align-items: center;
        gap: 6px;
      "
      onmouseover="this.style.background='var(--orange-dark)';this.style.transform='translateY(-2px)'"
      onmouseout="this.style.background='var(--orange)';this.style.transform='translateY(0)'">
        🛠️ Tech Stack
      </a>
      <a href="#about" style="
        padding: 10px 22px;
        background: transparent;
        color: var(--ink);
        border: 1.5px solid var(--border);
        border-radius: 99px;
        text-decoration: none;
        font-weight: 500;
        font-size: 0.9rem;
        transition: all 0.15s;
      "
      onmouseover="this.style.borderColor='var(--orange)';this.style.color='var(--orange)';this.style.transform='translateY(-2px)'"
      onmouseout="this.style.borderColor='var(--border)';this.style.color='var(--ink)';this.style.transform='translateY(0)'">
        About me →
      </a>
    </div>
  </div>

  <!-- Scroll indicator -->
  <div style="
    position: absolute;
    bottom: 2rem;
    left: 50%;
    transform: translateX(-50%);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 4px;
    opacity: 0.4;
    animation: float 2s ease-in-out infinite;
  ">
    <span style="font-size: 0.65rem; font-family: var(--mono); color: var(--ink-faint); letter-spacing: 0.1em;">scroll</span>
    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" color="var(--ink-faint)">
      <path d="M12 5v14M5 12l7 7 7-7"/>
    </svg>
  </div>
</section>

<style>
@keyframes fadeUp {
  from { opacity: 0; transform: translateY(20px); }
  to { opacity: 1; transform: translateY(0); }
}
@keyframes pulse-dot {
  0%, 100% { box-shadow: 0 0 0 3px rgba(34,197,94,0.2); }
  50% { box-shadow: 0 0 0 6px rgba(34,197,94,0.1); }
}
@keyframes float {
  0%, 100% { transform: translateX(-50%) translateY(0); }
  50% { transform: translateX(-50%) translateY(-6px); }
}
</style>
