---
---
<nav style="
  position: fixed;
  top: 0; left: 0; right: 0;
  z-index: 50;
  padding: 1rem 1.5rem;
  display: flex;
  align-items: center;
  justify-content: space-between;
  background: rgba(253,250,246,0.85);
  backdrop-filter: blur(12px);
  border-bottom: 1px solid rgba(26,21,18,0.06);
">
  <a href="#hero" style="
    font-family: var(--display);
    font-size: 1.1rem;
    font-weight: 800;
    color: var(--ink);
    text-decoration: none;
    display: flex;
    align-items: center;
    gap: 6px;
  ">
    <span class="animate-wiggle" style="display:inline-block; font-size:1.2rem;">🐈</span>
    <span>c-oyen</span>
  </a>

  <div style="display: flex; align-items: center; gap: 0.25rem;">
    <a href="#about" style="padding: 6px 12px; font-size: 0.85rem; color: var(--ink-muted); text-decoration: none; border-radius: 8px; transition: all 0.15s;" 
       onmouseover="this.style.color='var(--orange)';this.style.background='var(--orange-pale)'"
       onmouseout="this.style.color='var(--ink-muted)';this.style.background='transparent'">about</a>
    <a href="#stack" style="padding: 6px 12px; font-size: 0.85rem; color: var(--ink-muted); text-decoration: none; border-radius: 8px; transition: all 0.15s;"
       onmouseover="this.style.color='var(--orange)';this.style.background='var(--orange-pale)'"
       onmouseout="this.style.color='var(--ink-muted)';this.style.background='transparent'">stack</a>
    <a href="#focus" style="padding: 6px 12px; font-size: 0.85rem; color: var(--ink-muted); text-decoration: none; border-radius: 8px; transition: all 0.15s;"
       onmouseover="this.style.color='var(--orange)';this.style.background='var(--orange-pale)'"
       onmouseout="this.style.color='var(--ink-muted)';this.style.background='transparent'">focus</a>
    <a href="https://github.com/c-oyen" target="_blank" style="
      margin-left: 8px;
      padding: 7px 16px;
      font-size: 0.82rem;
      font-weight: 600;
      color: white;
      background: var(--ink);
      text-decoration: none;
      border-radius: 99px;
      transition: all 0.15s;
      display: flex;
      align-items: center;
      gap: 6px;
    "
    onmouseover="this.style.background='var(--orange)'"
    onmouseout="this.style.background='var(--ink)'">
      <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/></svg>
      GitHub
    </a>
  </div>
</nav>
